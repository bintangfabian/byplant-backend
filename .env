# ============================================================
# PlantWatch Backend — Environment Variables
# Salin file ini jadi .env dan isi nilainya
# JANGAN commit file .env ke Git!
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# HiveMQ Cloud — ambil dari dashboard Connection Details
MQTT_BROKER=d06bc2999e0a43f08cc4e48c7b9f6ade.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME= byhund
MQTT_PASSWORD=Password123
MQTT_CLIENT_ID=plantwatch-backend-001

# CORS — URL frontend kamu (untuk production ganti dengan URL Vercel)
CORS_ORIGIN=http://localhost:5173

# Database SQLite (path relatif dari folder backend)
DB_PATH=./plantwatch.db

# Simpan berapa banyak data historis (jam)
HISTORY_HOURS=24
